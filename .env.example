# Copy to .env and adjust as needed:  cp .env.example .env
# .env is gitignored; this file is the committed template.

# --- TimescaleDB / Postgres ---
POSTGRES_USER=fluxtape
POSTGRES_PASSWORD=fluxtape
POSTGRES_DB=fluxtape

# Connection string for local services (host -> container published port)
DATABASE_URL=postgres://fluxtape:fluxtape@localhost:5432/fluxtape?sslmode=disable

# --- Redpanda (Kafka API) ---
# Use the 'external' advertised listener from host apps:
KAFKA_BROKERS=localhost:19092

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Grafana ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
